# -----------------------------------------------------------------------
# Lead Conversion System — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it is already in .gitignore).
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------

# Path to the SQLite database file.
# Defaults to <repo_root>/tmp/app.db when not set.
# Set this to use a different location (e.g. a shared network path).
# DB_PATH=tmp/app.db


# -----------------------------------------------------------------------
# API Authentication  (Milestone 2 — not active in MVP)
# -----------------------------------------------------------------------

# Bearer token required on all API requests.
# All clients must send:  Authorization: Bearer <value>
# Must be compared constant-time; never logged.
# API_KEY=change-me-before-production


# -----------------------------------------------------------------------
# GoHighLevel Integration  (optional — not active in MVP)
# -----------------------------------------------------------------------

# GHL private integration token for contact writes.
# GHL_API_KEY=

# GHL location/sub-account ID.
# GHL_LOCATION_ID=

# Base URL for GHL API (default is the public v2 API).
# GHL_API_BASE_URL=https://services.leadconnectorhq.com


# -----------------------------------------------------------------------
# Outbound Webhooks  (optional)
# -----------------------------------------------------------------------

# URL to receive course events (student_started_course, course_completed).
# Leave unset to disable all outbound event emission.
# WEBHOOK_URL=https://your-endpoint.example.com/course-events


# -----------------------------------------------------------------------
# Backend Server
# -----------------------------------------------------------------------

# Host and port for uvicorn.
# Run with:  uvicorn backend.main:app --host $HOST --port $PORT
# HOST=0.0.0.0
# PORT=8000


# -----------------------------------------------------------------------
# Streamlit UI  (if running portals)
# -----------------------------------------------------------------------

# OpenAI API key for the AI Tutor in the student portal.
# OPENAI_API_KEY=
